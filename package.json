{
  "name": "medxpertshub-landing",
  "version": "1.0.0",
  "description": "MedXpertsHub medical/health editorial landing page — Figma to HTML/SCSS, compiled by Dart Sass on Node.",
  "private": true,
  "scripts": {
    "dev": "sass --watch src/scss/main.scss:dist/css/main.css --style=expanded --source-map",
    "build": "sass src/scss/main.scss:dist/css/main.css --style=compressed --no-source-map",
    "start": "npm run dev"
  },
  "devDependencies": {
    "sass": "^1.77.0"
  }
}
